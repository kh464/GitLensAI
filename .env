# .env 文件 (此文件在企业中不应提交到 Git 仓库)

# === 项目基础配置 ===
PROJECT_NAME="GitHub CodeSense Enterprise API"
VERSION="2.0.0"
CORS_ORIGINS="*"

# === 大模型配置 ===
GEMINI_API_KEY="在这里填入你的_GEMINI_API_KEY"
# 将大模型的 URL 抽离，方便未来升级模型版本（如从 2.5 升级到 3.0，无需修改代码）
GEMINI_MODEL_URL="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent"
AI_API_TIMEOUT=30.0

# === 第三方服务配置 ===
GITHUB_API_TIMEOUT=15.0